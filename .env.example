# Environment Variables Template
# Copy this file to .env and fill in your values

# ═══════════════════════════════════════════════════════════════════════════
# REQUIRED
# ═══════════════════════════════════════════════════════════════════════════

# HuggingFace token (required for model access)
HF_TOKEN=hf_your_token_here

# Neo4j database password
NEO4J_PASSWORD=change-me-in-production

# ═══════════════════════════════════════════════════════════════════════════
# OPTIONAL - Azure AI Enrichment
# ═══════════════════════════════════════════════════════════════════════════

# Azure OpenAI configuration (for swarm enrichment)
AZURE_API_KEY=
AZURE_ENDPOINT=https://your-resource.openai.azure.com/openai/v1
AZURE_MODEL=Kimi-K2.5

# ═══════════════════════════════════════════════════════════════════════════
# OPTIONAL - Firebase Authentication
# ═══════════════════════════════════════════════════════════════════════════

FIREBASE_PROJECT_ID=
FIREBASE_API_KEY=
FIREBASE_AUTH_DOMAIN=

# ═══════════════════════════════════════════════════════════════════════════
# OPTIONAL - Service Configuration
# ═══════════════════════════════════════════════════════════════════════════

# Fathom model endpoint (default: localhost)
FATHOM_ENDPOINT=http://localhost:8000

# Neo4j connection
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j

# API authentication tokens (comma-separated)
API_TOKENS=

# ═══════════════════════════════════════════════════════════════════════════
# OPTIONAL - Observability
# ═══════════════════════════════════════════════════════════════════════════

# Langfuse tracing (optional)
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=https://cloud.langfuse.com
