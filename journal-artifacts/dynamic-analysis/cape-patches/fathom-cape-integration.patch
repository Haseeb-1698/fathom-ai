+def _prefer_direct_child(child: sfFile) -> bool:
+    """Prefer the extracted child itself over its nested internals when it is a real launch target."""
+    filename = child.filename.decode(errors="ignore") if isinstance(child.filename, bytes) else child.filename
+    _, ext = os.path.splitext(filename)
+    ext = ext.lower()
+    if ext in DIRECT_CHILD_EXTENSIONS:
+        return True
+
+    package = (child.package or "").lower()
+    if package in VALID_PACKAGES:
+        return True
+
+    magic = child.magic or ""
+    if any(marker in magic for marker in OFFICE_TYPES):
+        return True
+
+    return False
+
